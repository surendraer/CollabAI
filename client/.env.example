# ============================================================================
# COLLABAI CLIENT ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env and update values for your deployment
# ============================================================================

# ─── API Configuration ───
# For local development: http://localhost:5000/api
# For production: https://api.yourdomain.com/api
VITE_API_URL=http://localhost:5000/api

# ─── WebSocket Configuration ───
# For local development: http://localhost:5000
# For production: https://yourdomain.com or wss://yourdomain.com
VITE_SOCKET_URL=http://localhost:5000

# ─── App Configuration ───
# Application name displayed in UI
VITE_APP_NAME=CollabAI

# ─── Optional: Analytics ───
# For tracking user interactions (e.g., Google Analytics, Mixpanel)
# VITE_ANALYTICS_KEY=

# ─── Optional: Feature Flags ───
# Enable/disable features without deploying code
# VITE_ENABLE_AI_FEATURES=true
# VITE_ENABLE_ANALYTICS=false

